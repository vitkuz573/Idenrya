{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=/data/idenrya.db"
  },
  "IdentityProvider": {
    "Issuer": "https://oidcc-provider:3000",
    "SupportedScopes": [
      "openid",
      "profile",
      "email",
      "address",
      "phone",
      "offline_access"
    ],
    "Credentials": {
      "AllowDevelopmentCertificates": true
    },
    "DynamicClientRegistration": {
      "Enabled": true,
      "AllowUnsignedIdTokens": true
    },
    "Bootstrap": {
      "Enabled": true,
      "Clients": [],
      "Users": [
        {
          "UserName": "foo",
          "Password": "bar",
          "Email": "foo@idenrya.local",
          "EmailConfirmed": true,
          "PhoneNumber": "+1-555-0100",
          "PhoneNumberConfirmed": true,
          "GivenName": "Conformance",
          "FamilyName": "User",
          "Address": "123 Test Street, Test City",
          "Claims": {
            "middle_name": "Q",
            "nickname": "foo",
            "profile": "https://idenrya.local/users/foo",
            "picture": "https://idenrya.local/assets/foo.png",
            "website": "https://idenrya.local",
            "gender": "unspecified",
            "birthdate": "1970-01-01",
            "zoneinfo": "America/New_York",
            "locale": "en-US",
            "updated_at": "1700000000"
          }
        }
      ]
    }
  },
  "OpenIdProviderCompatibility": {
    "RewriteDiscoveryRequestParameterSupported": true,
    "RewriteDiscoveryScopesSupported": true,
    "RewriteDiscoveryRegistrationEndpoint": true,
    "RewriteDiscoveryRequestUriParameterSupported": true,
    "EnableRequestObjectParameterSupport": true,
    "RejectRequestUriParameter": false,
    "RequestUriFetchTimeoutSeconds": 10,
    "AllowUnsafeRequestUriTlsValidation": true
  }
}
