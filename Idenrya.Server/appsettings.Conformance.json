{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=/data/idenrya.db"
  },
  "IdentityProvider": {
    "Issuer": "https://oidcc-provider:3000",
    "Credentials": {
      "AllowDevelopmentCertificates": true
    },
    "Bootstrap": {
      "Enabled": true,
      "Clients": [
        {
          "ClientId": "idenrya-basic-client",
          "ClientSecret": "idenrya-basic-secret",
          "DisplayName": "Idenrya basic conformance client #1",
          "RedirectUris": [
            "https://nginx:8443/test/a/idenrya-basic/callback"
          ],
          "Scopes": [
            "openid",
            "profile",
            "email",
            "address",
            "phone",
            "offline_access"
          ]
        },
        {
          "ClientId": "idenrya-basic-client-2",
          "ClientSecret": "idenrya-basic-secret-2",
          "DisplayName": "Idenrya basic conformance client #2",
          "RedirectUris": [
            "https://nginx:8443/test/a/idenrya-basic/callback"
          ],
          "Scopes": [
            "openid",
            "profile",
            "email",
            "address",
            "phone",
            "offline_access"
          ]
        }
      ],
      "Users": [
        {
          "UserName": "foo",
          "Password": "bar",
          "Email": "foo@idenrya.local",
          "EmailConfirmed": true,
          "PhoneNumber": "+1-555-0100",
          "PhoneNumberConfirmed": true,
          "GivenName": "Conformance",
          "FamilyName": "User",
          "Address": "123 Test Street, Test City",
          "Claims": {
            "middle_name": "Q",
            "nickname": "foo",
            "profile": "https://idenrya.local/users/foo",
            "picture": "https://idenrya.local/assets/foo.png",
            "website": "https://idenrya.local",
            "gender": "unspecified",
            "birthdate": "1970-01-01",
            "zoneinfo": "America/New_York",
            "locale": "en-US",
            "updated_at": "1700000000"
          }
        }
      ]
    }
  },
  "OpenIdProviderCompatibility": {
    "RewriteDiscoveryRequestParameterSupported": true,
    "EnableRequestObjectParameterSupport": true,
    "RejectRequestUriParameter": true
  }
}
