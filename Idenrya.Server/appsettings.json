{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=idenrya.db"
  },
  "IdentityProvider": {
    "SupportedScopes": [
      "openid",
      "profile",
      "email",
      "address",
      "phone",
      "offline_access"
    ],
    "Credentials": {
      "AllowDevelopmentCertificates": false
    },
    "Bootstrap": {
      "Enabled": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
