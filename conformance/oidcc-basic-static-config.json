    "oidcc-ensure-registered-redirect-uri": {
      "browser": [
        {
          "match": "https://oidcc-provider:3000/connect/authorize*",
          "tasks": [
            {
              "task": "Expect redirect uri mismatch error page",
              "match": "https://oidcc-provider:3000/connect/authorize*",
              "commands": [
                [
                  "wait",
                  "xpath",
                  "//*",
                  10,
                  "oops! something went wrong",
                  "update-image-placeholder"
                ]
              ]
            }
          ]
        }
      ]
    },
