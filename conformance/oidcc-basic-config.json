{
  "alias": "idenrya-basic",
  "description": "Idenrya OIDC Core Basic (all variants)",
  "server": {
    "discoveryUrl": "https://oidcc-provider:3000/.well-known/openid-configuration",
    "issuer": "https://oidcc-provider:3000/",
    "authorization_endpoint": "https://oidcc-provider:3000/connect/authorize",
    "token_endpoint": "https://oidcc-provider:3000/connect/token",
    "userinfo_endpoint": "https://oidcc-provider:3000/connect/userinfo",
    "jwks_uri": "https://oidcc-provider:3000/.well-known/jwks",
    "registration_endpoint": "https://oidcc-provider:3000/connect/register",
    "end_session_endpoint": "https://oidcc-provider:3000/connect/logout",
    "revocation_endpoint": "https://oidcc-provider:3000/connect/revocation",
    "introspection_endpoint": "https://oidcc-provider:3000/connect/introspect",
    "grant_types_supported": [
      "authorization_code",
      "refresh_token"
    ],
    "response_types_supported": [
      "code"
    ],
    "response_modes_supported": [
      "query",
      "form_post",
      "fragment"
    ],
    "scopes_supported": [
      "openid",
      "profile",
      "email",
      "address",
      "phone",
      "offline_access"
    ],
    "claims_supported": [
      "aud",
      "exp",
      "iat",
      "iss",
      "sub"
    ],
    "id_token_signing_alg_values_supported": [
      "RS256",
      "none"
    ],
    "code_challenge_methods_supported": [
      "plain",
      "S256"
    ],
    "subject_types_supported": [
      "public"
    ],
    "prompt_values_supported": [
      "consent",
      "login",
      "none",
      "select_account"
    ],
    "token_endpoint_auth_methods_supported": [
      "client_secret_basic",
      "client_secret_post",
      "private_key_jwt"
    ],
    "request_parameter_supported": true,
    "request_uri_parameter_supported": true
  },
  "client": {
    "client_id": "idenrya_static_client_basic",
    "client_secret": "idenrya_static_client_basic_secret_123456",
    "client_name": "Idenrya basic client #1"
  },
  "client2": {
    "client_id": "idenrya_static_client_second",
    "client_secret": "idenrya_static_client_second_secret_123456",
    "client_name": "Idenrya basic client #2"
  },
  "client_secret_post": {
    "client_id": "idenrya_static_client_post",
    "client_secret": "idenrya_static_client_post_secret_123456"
  },
  "browser": [
    {
      "match": "https://oidcc-provider:3000/connect/authorize*",
      "tasks": [
        {
          "task": "Login",
          "optional": true,
          "match": "https://oidcc-provider:3000/account/login*",
          "commands": [
            [
              "text",
              "name",
              "login",
              "foo",
              "optional"
            ],
            [
              "text",
              "name",
              "password",
              "bar",
              "optional"
            ],
            [
              "click",
              "class",
              "login-submit"
            ]
          ]
        },
        {
          "task": "Verify Complete",
          "match": "*/test/*/callback*",
          "commands": [
            [
              "wait",
              "id",
              "submission_complete",
              10
            ]
          ]
        }
      ]
    }
  ],
  "override": {
    "oidcc-prompt-login": {
      "browser": [
        {
          "match": "https://oidcc-provider:3000/connect/authorize*",
          "tasks": [
            {
              "task": "Login",
              "optional": true,
              "match": "https://oidcc-provider:3000/account/login*",
              "commands": [
                [
                  "wait",
                  "xpath",
                  "//*",
                  10,
                  "Sign-in",
                  "update-image-placeholder-optional"
                ],
                [
                  "text",
                  "name",
                  "login",
                  "foo",
                  "optional"
                ],
                [
                  "text",
                  "name",
                  "password",
                  "bar",
                  "optional"
                ],
                [
                  "click",
                  "class",
                  "login-submit"
                ]
              ]
            },
            {
              "task": "Verify Complete",
              "match": "*/test/*/callback*",
              "commands": [
                [
                  "wait",
                  "id",
                  "submission_complete",
                  10
                ]
              ]
            }
          ]
        }
      ]
    },
